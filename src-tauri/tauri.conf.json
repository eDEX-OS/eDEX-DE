{
  "productName": "eDEX-DE",
  "version": "0.5.0",
  "identifier": "io.edex.de",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "eDEX-DE",
        "width": 1920,
        "height": 1080,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0 | libwebkit2gtk-4.0-37",
          "libgtk-3-0",
          "libssl3 | libssl1.1",
          "libayatana-appindicator3-1 | libappindicator3-1"
        ]
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1 | webkit2gtk3",
          "gtk3",
          "openssl-libs"
        ]
      }
    }
  }
}
