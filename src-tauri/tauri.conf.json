{
  "productName": "eDEX-DE",
  "version": "0.13.1",
  "identifier": "io.edex.de",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "eDEX-DE",
        "width": 1920,
        "height": 1080,
        "fullscreen": true,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "rpm",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "\u00a9 2024 eDEX-DE Contributors",
    "license": "GPL-3.0",
    "category": "Utility",
    "shortDescription": "Sci-fi Desktop Environment for Hyprland",
    "longDescription": "eDEX-DE is a sci-fi themed Wayland desktop environment built on Tauri v2 and Hyprland. Features a terminal emulator, file manager, system monitor, app launcher, NetworkManager integration, systemd service manager, and PipeWire/PulseAudio audio control.",
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0 | libwebkit2gtk-4.0-37",
          "libgtk-3-0",
          "libayatana-appindicator3-1 | libappindicator3-1",
          "hyprland | sway",
          "curl"
        ],
        "recommends": [
          "pipewire-pulse | pulseaudio",
          "network-manager",
          "fprintd",
          "systemd"
        ],
        "section": "x11",
        "priority": "optional",
        "desktopTemplate": "../packaging/edex-de.desktop",
        "postInstallScript": "../packaging/linux/deb/postinst"
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1 | webkit2gtk4.0",
          "gtk3",
          "libappindicator-gtk3"
        ],
        "recommends": [
          "pipewire-pulse",
          "NetworkManager",
          "fprintd",
          "systemd"
        ],
        "epoch": 0,
        "release": "1",
        "desktopTemplate": "../packaging/edex-de.desktop",
        "postInstallScript": "../packaging/linux/rpm/postinst"
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
