#!/bin/sh
set -e

# Install Wayland session entry so eDEX-DE appears in the login screen
install -Dm644 /usr/share/edex-de/edex-de-session.desktop \
    /usr/share/wayland-sessions/edex-de.desktop 2>/dev/null || true

# Install session startup script
install -Dm755 /usr/share/edex-de/edex-de-session \
    /usr/bin/edex-de-session 2>/dev/null || true

# Install bundled Hyprland config
install -Dm644 /usr/share/edex-de/hyprland.conf \
    /etc/xdg/edex-de/hyprland.conf 2>/dev/null || true

if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database /usr/share/applications >/dev/null 2>&1 || true
fi

if command -v gtk-update-icon-cache >/dev/null 2>&1; then
    gtk-update-icon-cache -q /usr/share/icons/hicolor >/dev/null 2>&1 || true
fi

exit 0
