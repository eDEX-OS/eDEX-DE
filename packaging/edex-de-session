#!/usr/bin/env bash
# eDEX-DE session startup script
# Installed to /usr/bin/edex-de-session
# Selected by the display manager as the "eDEX-DE" Wayland session.
set -euo pipefail

# ── Environment ──────────────────────────────────────────────────────────────
export XDG_CURRENT_DESKTOP=eDEX-DE
export XDG_SESSION_DESKTOP=eDEX-DE
export XDG_SESSION_TYPE=wayland
export MOZ_ENABLE_WAYLAND=1
export MOZ_WEBRENDER=1
export QT_QPA_PLATFORM=wayland
export QT_WAYLAND_DISABLE_WINDOWDECORATION=1
export SDL_VIDEODRIVER=wayland
export CLUTTER_BACKEND=wayland
export GDK_BACKEND=wayland
export _JAVA_AWT_WM_NONREPARENTING=1
export ELECTRON_OZONE_PLATFORM_HINT=wayland

# Propagate to D-Bus / systemd user session
dbus-update-activation-environment --systemd \
    XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP XDG_SESSION_TYPE \
    MOZ_ENABLE_WAYLAND QT_QPA_PLATFORM SDL_VIDEODRIVER \
    CLUTTER_BACKEND GDK_BACKEND WAYLAND_DISPLAY 2>/dev/null || true

# ── Daemons required before Hyprland starts ───────────────────────────────────
# Polkit — privilege escalation dialogs (needed for many system operations)
for agent in \
    /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 \
    /usr/lib/polkit-kde-authentication-agent-1 \
    /usr/lib/lxpolkit/lxpolkit \
    /usr/bin/lxpolkit; do
    if [[ -x "$agent" ]]; then
        "$agent" &
        break
    fi
done

# PipeWire audio stack (pipewire-pulse replaces pulseaudio socket)
if command -v pipewire &>/dev/null; then
    pipewire &
    sleep 0.3
    if command -v wireplumber &>/dev/null; then
        wireplumber &
    fi
    if command -v pipewire-pulse &>/dev/null; then
        pipewire-pulse &
    fi
fi

# XDG Desktop Portals — file chooser, screen share, etc.
# Must start before any app that uses portals (including the eDEX app).
if command -v xdg-desktop-portal-hyprland &>/dev/null; then
    xdg-desktop-portal-hyprland &
    sleep 0.5
fi
if command -v xdg-desktop-portal &>/dev/null; then
    xdg-desktop-portal &
fi

# Clipboard history (wl-clipboard + cliphist)
if command -v wl-paste &>/dev/null && command -v cliphist &>/dev/null; then
    wl-paste --type text  --watch cliphist store &
    wl-paste --type image --watch cliphist store &
elif command -v wl-paste &>/dev/null; then
    # cliphist not installed — just keep wl-clipboard running
    wl-paste --type text --watch cat >/dev/null &
fi

# Notification daemon (mako preferred, dunst fallback)
if command -v mako &>/dev/null; then
    mako &
elif command -v dunst &>/dev/null; then
    dunst &
fi

# Idle/lock daemon (swayidle for screen timeout and suspend)
if command -v swayidle &>/dev/null; then
    swayidle -w \
        timeout 300  'hyprctl dispatch dpms off' \
        resume       'hyprctl dispatch dpms on'  \
        timeout 600  'systemctl suspend' &
fi

# ── Start Hyprland with the eDEX-DE config ───────────────────────────────────
# HYPRLAND_CONFIG points Hyprland at our bundled config.
# Users may place overrides in ~/.config/edex-de/hyprland-extra.conf.
exec env HYPRLAND_CONFIG=/etc/xdg/edex-de/hyprland.conf Hyprland
